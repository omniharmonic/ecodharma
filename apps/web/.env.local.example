# Copy to .env.local. Local-dev defaults shown.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
EPHEMERIS_URL=http://127.0.0.1:8000
# EPHEMERIS_TOKEN=        # set to enable bearer auth on the ephemeris service
SESSION_SECRET=dev-only-insecure-secret-change-me-please-32b
# Path to the distilled framework artifact (falls back to a built-in stub if absent).
FRAMEWORK_PATH=../../framework/framework.json
VOICE_PATH=../../framework/voice/ecodharma-voice@1.0.0.md
# Optional: when set, the interpreter uses real Claude; otherwise a deterministic
# framework-driven fixture interpreter runs (fully offline, e2e-testable).
# ANTHROPIC_API_KEY=
