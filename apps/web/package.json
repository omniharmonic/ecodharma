{
  "name": "ecodharma-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "mcp": "npx tsx src/mcp/server.ts",
    "mcp:smoke": "npx tsx src/mcp/smoke.mts",
    "sync:framework": "node -e \"const fs=require('fs');fs.mkdirSync('framework/voice',{recursive:true});fs.copyFileSync('../../framework/framework.json','framework/framework.json');fs.copyFileSync('../../framework/voice/ecodharma-voice@2.0.0.md','framework/voice/ecodharma-voice@2.0.0.md');console.log('synced repo-root framework/ into apps/web/framework for deploy bundling')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "jose": "^5.9.6",
    "next": "14.2.15",
    "pg": "^8.13.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.48.2",
    "@types/node": "^20.16.13",
    "@types/pg": "^8.11.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
